<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Maison du Café - Products</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<header class="site-header">
    <div class="brand">
        <h1>Maison du Café</h1>
    </div>
    <nav class="top-nav">
        <ul>
            <li><a href="/" class="active">Home</a></li>
            <li><a href="/menu">Menu</a></li>
            <li><a href="/login">Login</a></li>
        </ul>
    </nav>

    <!-- HERO MUST BE INSIDE HEADER -->
    <div class="hero" role="img" aria-label="Coffee beans background"></div>
</header>

<main class="content" style="max-width:1100px; margin:40px auto; padding:0 20px;">

    <!-- ADD PRODUCT BUTTON HERE -->
    <div class="menu-actions">
        <a href="/add-product" class="btn-add-product">➕ Add New Product</a>
    </div>

    <section id="products">
        <h2>Our Products</h2>
        <div class="card-grid">
            <% products.forEach(product => { %>
                <article class="card">
                    <img src="<%= product.imageUrl || '/images/default.jpg' %>" alt="<%= product.name %>">
                    <div class="card-body">
                        <h3><%= product.name %></h3>
                        <p><%= product.description || 'No description available.' %></p>
                        <p class="price">$<%= Number(product.price).toFixed(2) %></p>
                        <a class="btn" href="/product/<%= product.id %>">View Details</a>
                    </div>
                </article>
            <% }) %>
        </div>
    </section>
</main>

<footer class="site-footer">
    <p>© 2025 Maison du Café • Grodno • <a href="/contact">Contact</a></p>
</footer>

</body>
</html>
