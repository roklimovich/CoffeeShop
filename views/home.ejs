<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Maison du Café</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="quiz-overlay" id="quizOverlay">
    <div class="quiz-box">
        <h2>☕ Coffee Quiz</h2>
        <p>Click the steps in the correct order to make your perfect cup!</p>

        <div class="quiz-steps" id="quizSteps">
            <div class="quiz-step" data-step="1">Add coffee grounds</div>
            <div class="quiz-step" data-step="2">Pour hot water</div>
            <div class="quiz-step" data-step="3">Stir and wait</div>
            <div class="quiz-step" data-step="4">Add milk or sugar</div>
        </div>

        <div class="quiz-result" id="quizResult">Your order:</div>
        <div class="quiz-message" id="quizMessage"></div>
        <button class="quiz-close" id="quizClose">❌ Close</button>
    </div>
</div>

<script src="quiz.js" defer></script>

<header class="site-header">
    <div class="brand">
        <h1>Maison du Café</h1>
    </div>
    <nav class="top-nav" aria-label="Primary">
        <ul>
            <li><a href="/home">Home</a></li>
            <li><a href="/menu">Menu</a></li>
            <li><a href="/contact">Contact</a></li>
            <li><a href="/login">Login</a></li>
        </ul>
    </nav>
    <div class="hero" role="img" aria-label="Coffee beans background"></div>
</header>

<div class="layout" id="home">
    <aside class="sidebar" aria-label="Secondary navigation">
        <h2>Quick navigation</h2>
        <nav class="side-links">
            <ul>
                <li><a href="#about">About us</a></li>
                <li><a href="#menu">Our menu</a></li>
                <li><a href="#specials">Weekly specials</a></li>
                <li><a href="#loyalty">Loyalty program</a></li>
            </ul>
        </nav>
    </aside>

    <main class="content">
        <section id="about">
            <h2>Welcome to Maison du Café</h2>
            <p>
                We are a neighborhood coffee house dedicated to craft brewing and warm hospitality.
                From classic espresso to slow‑brew pour overs, our baristas bring out the best in every bean.
            </p>
            <p>
                Planning your first visit? Here is what to expect:
            </p>
            <ol>
                <li>Greeted with a smile and aroma of freshly ground coffee.</li>
                <li>Curated menu featuring signature drinks and seasonal specials.</li>
                <li>Comfortable seating, soft music, and outlets for your laptop.</li>
            </ol>
        </section>

        <section id="menu">
            <h2>Customer choice</h2>
            <div class="card-grid">
                <article class="card">
                    <img src="https://media.decofire.pl/pub/media/wysiwyg/cappuccino-ziarna-kawy.jpg" alt="Cappuccino">
                    <div class="card-body">
                        <h3>Cappuccino</h3>
                        <p>Velvety foam with a rich espresso base.</p>
                        <p class="price">$4.50</p>
                    </div>
                </article>
                <article class="card">
                    <img src="https://images.unsplash.com/photo-1517701604599-bb29b565090c?q=80&w=600&auto=format&fit=crop"
                         alt="Iced latte">
                    <div class="card-body">
                        <h3>Iced Latte</h3>
                        <p>Chilled espresso, milk, and a touch of sweetness.</p>
                        <p class="price">$5.20</p>
                    </div>
                </article>
                <article class="card">
                    <img src="https://dynamic-media-cdn.tripadvisor.com/media/photo-o/26/74/b3/53/coffee.jpg?w=900&h=500&s=1"
                         alt="Croissant">
                    <div class="card-body">
                        <h3>Butter Croissant</h3>
                        <p>Flaky, buttery layers baked fresh every morning.</p>
                        <p class="price">$3.20</p>
                    </div>
                </article>
            </div>
        </section>

        <section id="specials">
            <h2>Weekly specials</h2>
            <table class="specials-table">
                <thead>
                <tr>
                    <th>Day</th>
                    <th>Item</th>
                    <th>Price</th>
                    <th>Status</th>
                </tr>
                </thead>
                <tbody>
                <tr>
                    <td>Monday</td>
                    <td>Flat White</td>
                    <td>$4.80</td>
                    <td>Available</td>
                </tr>
                <tr>
                    <td>Wednesday</td>
                    <td>Mocha</td>
                    <td>$5.10</td>
                    <td>Available</td>
                </tr>
                <tr>
                    <td>Friday</td>
                    <td>Blueberry Muffin</td>
                    <td>$2.90</td>
                    <td>Limited</td>
                </tr>
                </tbody>
            </table>

            <p class="note">
                Our coffee shop looks like:
                <img class="coffee-shop-desc"
                     src="https://dynamic-media-cdn.tripadvisor.com/media/photo-o/19/3f/6a/c1/photo0jpg.jpg?w=900&h=500&s=1"
                     alt="Coffee shop location">
            </p>
        </section>

        <section id="loyalty">
            <h2>Loyalty program</h2>
            <p>Collect stamps and enjoy free drinks and exclusive menu.</p>
            <ul>
                <li>Buy 9 drinks, get the 10th free</li>
                <li>Early access to seasonal menu</li>
            </ul>
        </section>

        <section id="contact">
            <h2>Contact</h2>
            <p>Telephone:<a href="tel:+48000000000"> +48 000 000 000</a></p>
            <p>Email:<a href=mailto:s27619@pjwstk.edu.pl> s27619@pjwstk.edu.pl</a></p>
        </section>
    </main>
</div>

<footer class="site-footer">
    <p>
        © 2025 Maison du Café • Grodno •
        <a href="#contact">Contact</a>
    </p>
</footer>
</body>
</html>