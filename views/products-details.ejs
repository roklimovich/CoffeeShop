<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Maison du Café</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<header class="site-header">
    <div class="brand">
        <h1>Maison du Café</h1>
    </div>
    <nav class="top-nav" aria-label="Primary">
        <ul>
            <li><a href="/home">Home</a></li>
            <li><a href="/menu">Menu</a></li>
            <li><a href="/contact">Contact</a></li>
            <li><a href="/login">Login</a></li>
        </ul>
    </nav>
    <div class="hero" role="img" aria-label="Coffee beans background"></div>
</header>

<main>
    <div class="auth-container">
        <div class="auth-box glass">
            <h2>Details</h2>
            <form class="auth-form" action="/save-product/<%= product.id %>" method="POST">

                <label for="name">Product name</label>
                <input type="text" id="name" name="name" value="<%= product.name %>" required>

                <label for="price">Price ($)</label>
                <input type="number" step="0.01" id="price" name="price" value="<%= product.price %>" required>

                <label for="description">Description</label>
                <textarea id="description" name="description" required><%= product.description %></textarea>

                <label for="imageUrl">Image URL</label>
                <input type="url" id="imageUrl" name="imageUrl" value="<%= product.imageUrl %>" required>

                <button type="submit" class="auth-btn">Save product</button>
            </form>
        </div>
    </div>
</main>

<footer class="site-footer">
    <p>© 2025 Maison du Café • Grodno • <a href="/contact">Contact</a></p>
</footer>

</body>
</html>
